<!doctype html>
<html lang="{{ request.locale.iso_code }}">

<head>

<meta charset="utf-8">

<meta name="viewport" content="width=device-width,initial-scale=1">

<meta name="theme-color" content="#2563eb">

<title>

{{ page_title }}

{% if current_tags %}

– {{ current_tags | join: ", " }}

{% endif %}

{% if current_page != 1 %}

– Page {{ current_page }}

{% endif %}

{% unless page_title contains shop.name %}

– {{ shop.name }}

{% endunless %}

</title>

{{ content_for_header }}

{{ 'theme.css' | asset_url | stylesheet_tag }}

</head>

<body>

{% section 'header' %}

<div id="shipping-bar">

<div class="shipping-text"></div>

<div class="shipping-track">
<div class="shipping-fill"></div>
</div>

</div>

{% section 'announcement-bar' %}

<main id="MainContent">

{{ content_for_layout }}

</main>

{% section 'footer' %}

{{ 'theme.js' | asset_url | script_tag }}

<a href="/cart" class="floating-cart">
🛒 {{ cart.item_count }}
</a>

<script>
document.addEventListener("DOMContentLoaded", function(){
updateShippingBar();
});
</script>

</body>

</html>
