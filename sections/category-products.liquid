<section class="category-products">

<div class="category-header">

<h2>{{ section.settings.title }}</h2>

<a href="{{ section.settings.collection.url }}">
View all →
</a>

</div>


<div class="carousel-wrapper">

<button class="carousel-btn left" onclick="scrollProducts(this, -1)">
‹
</button>


<div class="product-scroll">


{% for product in section.settings.collection.products limit:10 %}

<div class="small-product-card">


<div class="product-image-box">

{% if forloop.index <= 2 %}
<span class="badge">
🔥 Trending
</span>
{% endif %}


<a href="{{ product.url }}">

<img 
src="{{ product.featured_image | image_url: width:400 }}"
alt="{{ product.title }}">

</a>

</div>


<h3>
{{ product.title }}
</h3>


<p>
{{ product.price | money }}
</p>


</div>


{% endfor %}


</div>


<button class="carousel-btn right" onclick="scrollProducts(this, 1)">
›
</button>


</div>

</section>


<script>

function scrollProducts(button, direction){

let container = button.parentElement.querySelector('.product-scroll');

container.scrollBy({
left: direction * 250,
behavior:'smooth'
});

}

</script>


{% schema %}
{
"name":"Category Products",
"settings":[
{
"type":"text",
"id":"title",
"label":"Category title"
},
{
"type":"collection",
"id":"collection",
"label":"Choose collection"
}
],
"presets":[
{
"name":"Category Products"
}
]
}
{% endschema %}
