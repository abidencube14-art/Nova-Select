<section class="product-page">

<div class="product-container">

<!-- IMAGE GALLERY -->
<div class="gallery">

<img id="mainImage" src="{{ product.featured_image | img_url: '600x' }}">

<div class="thumbnails">

{% for image in product.images %}
<img src="{{ image | img_url: '100x' }}" onclick="changeImage(this)">
{% endfor %}

</div>

</div>

<!-- PRODUCT INFO -->
<div class="product-info">

<h1>{{ product.title }}</h1>

<p class="price">{{ product.price | money }}</p>

<p class="stock" id="stockText">🟢 Only 7 left in stock</p>

<div class="reviews">

<h2>Customer Reviews</h2>

<div class="review">
<strong>⭐️⭐️⭐️⭐️⭐️</strong>
<p>"Amazing quality, fast shipping!"</p>
<span>- James M.</span>
</div>

<div class="review">
<strong>⭐️⭐️⭐️⭐️⭐️</strong>
<p>"Better than expected. Highly recommend."</p>
<span>- Jason K.</span>
</div>

<div class="review">
<strong>⭐️⭐️⭐️⭐️⭐️</strong>
<p>"Very good store, will buy again."</p>
<span>- David L.</span>
</div>

</div>

<!-- COUNTDOWN -->
<div class="countdown">
⏳ Offer ends in: <span id="timer">03:00:00</span>
</div>

<!-- SHIPPING -->
<div class="shipping-box">
🚚 Free shipping over $50  
📦 Delivery: 7–14 days worldwide
</div>

<!-- ADD TO CART -->
<form method="post" action="/cart/add">
<input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

<button type="submit" class="add-btn">
Add to Cart
</button>
</form>

<!-- TRUST -->
<div class="trust">
<p>🔒 Secure Checkout</p>
<p>💳 Safe Payments</p>
<p>📦 Worldwide Shipping</p>
</div>

</div>

</div>

</section>

<script>

// IMAGE SWITCH
function changeImage(el){
document.getElementById("mainImage").src = el.src;
}

// COUNTDOWN TIMER
let time = 3 * 60 * 60;

function updateTimer(){

let hrs = Math.floor(time / 3600);
let mins = Math.floor((time % 3600) / 60);
let secs = time % 60;

document.getElementById("timer").innerText =
hrs + ":" + mins + ":" + secs;

time--;

}

setInterval(updateTimer, 1000);

</script>

<div id="stickyCart">
  <span>{{ product.title }}</span>

  <form method="post" action="/cart/add">
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
    <button type="submit">Add to Cart - {{ product.price | money }}</button>
  </form>
</div>

<div class="fbt">

<h2>Frequently Bought Together</h2>

<div class="fbt-items">

<div class="fbt-item">
<p>✔ {{ product.title }}</p>
</div>

<div class="fbt-item">
<p>✔ Wireless Charger</p>
</div>

<div class="fbt-item">
<p>✔ USB Cable</p>
</div>

</div>

<p class="fbt-price">Bundle Price: Save 15%</p>

<button>Add Bundle to Cart</button>

</div>
