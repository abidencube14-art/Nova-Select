<div class="track-order-page">
  <div class="page-width">

    <h1>Track Your Order</h1>

    <p>
      Enter your tracking number below to check your shipment status.
    </p>

    <form id="trackForm">
      <input
        type="text"
        id="trackingNumber"
        placeholder="Enter Tracking Number"
      >

      <button type="submit">
        Track Order
      </button>
    </form>

    <div id="trackingResult"></div>

  </div>
</div>

<style>
.track-order-page{
padding:70px 20px;
text-align:center;
}

.track-order-page h1{
font-size:42px;
margin-bottom:15px;
}

.track-order-page p{
color:#666;
margin-bottom:30px;
}

.track-order-page input{
width:320px;
max-width:90%;
padding:15px;
border:1px solid #ddd;
border-radius:8px;
font-size:16px;
}

.track-order-page button{
padding:15px 30px;
background:#111;
color:white;
border:none;
border-radius:8px;
margin-left:10px;
cursor:pointer;
}

#trackingResult{
margin-top:30px;
font-size:18px;
font-weight:bold;
color:#2b9348;
}
</style>

<script>
document.addEventListener("DOMContentLoaded",function(){

const form=document.getElementById("trackForm");

if(!form) return;

form.addEventListener("submit",function(e){

e.preventDefault();

let number=document.getElementById("trackingNumber").value;

if(number==""){
document.getElementById("trackingResult").innerHTML="Please enter a tracking number.";
return;
}

document.getElementById("trackingResult").innerHTML=
"Tracking number <strong>"+number+"</strong> received.<br>Live shipment tracking will be connected soon.";

});

});
</script>
