<style>

.site-header{
  background: var(--bg);
}

.header-container{
display:flex;
justify-content:space-between;
align-items:center;
max-width:1200px;
margin:auto;
}

.logo{
  color: var(--primary);
}

.nav-links{
display:flex;
gap:20px;
}

.nav-links a{
text-decoration:none;
color:#333;
font-weight:500;
}

.nav-links a:hover{
color:#000;
}

.header-icons{
display:flex;
gap:15px;
font-size:18px;
}

.menu-toggle{
display:none;
font-size:26px;
cursor:pointer;
}

/* MOBILE */
.mobile-menu{
display:none;
flex-direction:column;
padding:15px;
background:white;
}

.mobile-menu a{
padding:10px 0;
border-bottom:1px solid #eee;
text-decoration:none;
color:#333;
}

@media(max-width:768px){

.nav-links{
display:none;
}

.menu-toggle{
display:block;
}

.mobile-menu.show{
display:flex;
}

}

</style>

<script>

function toggleMenu(){
document.getElementById("mobileMenu").classList.toggle("show");
}

// cart count (simple version)
fetch('/cart.js')
.then(res => res.json())
.then(cart => {
document.getElementById("cart-count").innerText = cart.item_count;
});

</script>
