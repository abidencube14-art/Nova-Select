<section class="hero-section">

  {% if section.settings.background_image != blank %}
    <div class="hero-image" style="background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');">
  {% else %}
    <div class="hero-image">
  {% endif %}

    <div class="hero-overlay">

      <div class="hero-content">

        <h1>{{ section.settings.heading }}</h1>

        <p>{{ section.settings.subheading }}</p>

        <a href="{{ section.settings.button_link }}" class="hero-button">

          {{ section.settings.button_text }}

        </a>

      </div>

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Upgrade Your Home. Power Your Lifestyle."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Affordable • Reliable • Premium Quality • Built to Last"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
